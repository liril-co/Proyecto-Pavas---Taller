{
  "info": {
    "name": "Taller Motos API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Coleccion con JWT y roles ADMIN/MECANICO"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register (bootstrap or ADMIN)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}", "disabled": true }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Admin Principal\",\n  \"email\": \"admin@taller.com\",\n  \"password\": \"Admin123\",\n  \"role\": \"ADMIN\"\n}"
            },
            "url": "{{baseUrl}}/auth/register"
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@taller.com\",\n  \"password\": \"Admin123\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/auth/me"
          }
        }
      ]
    },
    {
      "name": "Clients",
      "item": [
        {
          "name": "Create Client",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Juan Perez\",\n  \"phone\": \"3001234567\",\n  \"email\": \"juan@example.com\"\n}"
            },
            "url": "{{baseUrl}}/clients"
          }
        },
        {
          "name": "Get Clients",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/clients?search="
          }
        },
        {
          "name": "Get Client By Id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/clients/{{clientId}}"
          }
        }
      ]
    },
    {
      "name": "Bikes",
      "item": [
        {
          "name": "Create Bike",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"plate\": \"ABC123\",\n  \"brand\": \"Honda\",\n  \"model\": \"CB150\",\n  \"cylinder\": \"150\",\n  \"clientId\": 1\n}"
            },
            "url": "{{baseUrl}}/bikes"
          }
        },
        {
          "name": "Get Bikes",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/bikes?plate="
          }
        },
        {
          "name": "Get Bike By Id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/bikes/{{bikeId}}"
          }
        }
      ]
    },
    {
      "name": "Work Orders",
      "item": [
        {
          "name": "Create Work Order",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"motoId\": 1,\n  \"faultDescription\": \"No enciende\"\n}"
            },
            "url": "{{baseUrl}}/work-orders"
          }
        },
        {
          "name": "Get Work Orders",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/work-orders?status=&plate=&page=1&pageSize=10"
          }
        },
        {
          "name": "Get Work Order By Id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/work-orders/{{workOrderId}}"
          }
        },
        {
          "name": "Patch Work Order Status",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"DIAGNOSTICO\"\n}"
            },
            "url": "{{baseUrl}}/work-orders/{{workOrderId}}/status"
          }
        },
        {
          "name": "Add Work Order Item",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"MANO_OBRA\",\n  \"description\": \"Cambio aceite\",\n  \"count\": 1,\n  \"unitValue\": 45000\n}"
            },
            "url": "{{baseUrl}}/work-orders/{{workOrderId}}/items"
          }
        },
        {
          "name": "Delete Work Order Item",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/work-orders/items/{{itemId}}"
          }
        }
      ]
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api" },
    { "key": "token", "value": "" },
    { "key": "clientId", "value": "1" },
    { "key": "bikeId", "value": "1" },
    { "key": "workOrderId", "value": "1" },
    { "key": "itemId", "value": "1" }
  ]
}
